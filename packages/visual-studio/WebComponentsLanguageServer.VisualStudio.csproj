    <ProjectGuid>{2A0B7851-6A43-4434-A0D6-211D8C4D4D74}</ProjectGuid>
    <OutputType>Library</OutputType>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AppDesignerFolder>Properties</AppDesignerFolder>
